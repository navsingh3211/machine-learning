#one hot encoding
df_cleaned=pd.get_dummies(df_cleaned,columns=['transmission'])


df_cleaned.head()


bool_cols = df_cleaned.select_dtypes(include='bool').columns


df_cleaned[bool_cols] = df_cleaned[bool_cols].astype(int)


