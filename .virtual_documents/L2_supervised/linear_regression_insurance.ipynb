from scipy.stats import pearsonr

#---------------------
#Pearson correlation calculation (-1 to 1 in between)
#--------------------------

#List of faeture to check against the target
selected_features = [
    'age', 'is_female', 'bmi', 'children', 'is_smoker',
       'region_northwest', 'region_southeast', 'region_southwest',
       'bmi_category_Normal', 'bmi_category_Overweight', 'bmi_category_Obese'
]
correlations={
    feature: pearsonr(df_cleaned[feature],df_cleaned['charges'])[0]
    for feature in selected_features
}
correlation_df = pd.DataFrame(list(correlations.items()),columns=['Feature','Pearsonr Correlations'])
correlation_df.sort_values(by='Pearsonr Correlations',ascending=False)






cat_features = [
  'is_female','is_smoker',
       'region_northwest', 'region_southeast', 'region_southwest',
       'bmi_category_Normal', 'bmi_category_Overweight', 'bmi_category_Obese'
]


from scipy.stats import chi2_contingency
import pandas as pd

alpha = 0.05

df_cleaned['charges_bin']=pd.qcut(df_cleaned['charges'],q=4,labels=False)
chi2_result = {}
for col in cat_features:
    contingency = pd.crosstab(df_cleaned[col],df_cleaned['charges_bin'])
    chi2_stat,p_val,_,_ = chi2_contingency(contingency)
    decision = 'Reject Null (Keep features)' if p_val<alpha else 'Accept Null (Drop feature)'
    chi2_result[col]={
        'chi2_statistics' : chi2_stat,
        'p_value' : p_val,
        'decision' : decision
    }
chi2_df = pd.DataFrame(chi2_result).T
chi2_df = chi2_df.sort_values(by='p_value')
chi2_df


df_final = df_cleaned[['age', 'is_female', 'bmi', 'children', 'is_smoker','charges','region_southeast','bmi_category_Obese']]


df_final





from sklearn.model_selection import train_test_split


X = df_final.drop('charges',axis=1)
y = df_final["charges"]
X


X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.20, random_state=42)


X_train


X_test


y_train


from sklearn.linear_model import LinearRegression


model = LinearRegression()
model.fit(X_train, y_train)


y_pred = model.predict(X_test)
# y_pred


# y_test


from sklearn.metrics import r2_score
r2 = r2_score(y_test,y_pred)

#total rows in X_test
n=X_test.shape[0]
p=X_test.shape[1] #total cols in X_test

adjusted_r2 = 1 - ((1-r2)*(n-1))/(n-p-1)


print(r2)
print(adjusted_r2)



